{
  "name": "vermogen-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "validate:public": "node scripts/validate-public-build.mjs",
    "build:public": "node scripts/prepare-public-build.mjs",
    "check": "node --test tests/*.test.mjs && node scripts/validate-public-build.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  },
  "engines": {
    "node": ">=20"
  }
}
